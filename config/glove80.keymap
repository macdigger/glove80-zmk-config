  #define KEY_RH_C5R3 0
  #define KEY_RH_C6R3 0
  #define KEY_LH_C6R4 0
  #define KEY_LH_C5R4 KEY_LH_C5R4
  #define KEY_LH_C4R4 KEY_LH_C4R4
  #define KEY_LH_C3R4 KEY_LH_C3R4
  #define KEY_LH_C2R4 KEY_LH_C2R4
  #define KEY_LH_C1R4 0
  #define KEY_RH_C1R4 0
  #define KEY_RH_C2R4 KEY_RH_C2R4
  #define KEY_RH_C3R4 KEY_RH_C3R4
  #define KEY_RH_C4R4 KEY_RH_C4R4
  #define KEY_RH_C5R4 KEY_RH_C5R4
  #define KEY_RH_C6R4 0
  #define KEY_LH_C6R5 0
  #define KEY_LH_C5R5 0
  #define KEY_LH_C4R5 0
  #define KEY_LH_C3R5 0
  #define KEY_LH_C2R5 0
  #define KEY_LH_C1R5 0
  #define KEY_LH_T1 0
  #define KEY_LH_T2 0
  #define KEY_LH_T3 0
  #define KEY_RH_T3 0
  #define KEY_RH_T2 0
  #define KEY_RH_T1 0
  #define KEY_RH_C1R5 0
  #define KEY_RH_C2R5 0
  #define KEY_RH_C3R5 0
  #define KEY_RH_C4R5 0
