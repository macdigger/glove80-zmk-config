  #define KEY_LH_C2R2 0
  #define KEY_LH_C1R2 0
  #define KEY_RH_C1R2 0
  #define KEY_RH_C2R2 0
  #define KEY_RH_C3R2 0
  #define KEY_RH_C4R2 0
  #define KEY_RH_C5R2 0
  #define KEY_RH_C6R2 0
  #define KEY_LH_C6R3 0
  #define KEY_LH_C5R3 0
  #define KEY_LH_C4R3 0
  #define KEY_LH_C3R3 0
  #define KEY_LH_C2R3 0
  #define KEY_LH_C1R3 0
  #define KEY_RH_C1R3 0
  #define KEY_RH_C2R3 0
  #define KEY_RH_C3R3 0
